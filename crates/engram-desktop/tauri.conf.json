{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Engram",
  "version": "0.1.0",
  "identifier": "com.madup.engram",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ui dev",
    "beforeBuildCommand": "pnpm --dir ui build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Engram",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "single-instance": {},
    "notification": {}
  }
}
