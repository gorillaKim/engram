{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Engram",
  "version": "0.1.0",
  "identifier": "com.madup.engram",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../ui && pnpm dev",
    "beforeBuildCommand": "cd ../ui && pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Engram",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true
      },
      {
        "label": "tray_popover",
        "url": "tray.html",
        "width": 380,
        "height": 360,
        "visible": false,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "single-instance": null,
    "notification": null
  }
}
